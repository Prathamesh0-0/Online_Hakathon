datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                     String           @id @default(uuid())
  email                  String           @unique
  password               String
  name                   String
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  meetings               Meeting[]        @relation("HostMeetings")
  actionItems            ActionItem[]     @relation("AssigneeActionItems")
  teams                  Team[]           @relation("TeamMembers")
  sentChannelMessages    ChannelMessage[] @relation("SenderChannelMessages")
  sentDirectMessages     DirectMessage[]  @relation("SenderDirectMessages")
  receivedDirectMessages DirectMessage[]  @relation("ReceiverDirectMessages")
}

enum MeetingStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
}

model Meeting {
  id          String        @id @default(uuid())
  code        String?       @unique
  title       String
  description String?
  invitedEmails String?
  status      MeetingStatus @default(SCHEDULED)
  startTime   DateTime      @default(now())
  endTime     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  hostId      String
  host        User          @relation("HostMeetings", fields: [hostId], references: [id], onDelete: Cascade)
  
  channelId   String?
  channel     Channel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)

  transcripts Transcript[]
  actionItems ActionItem[]
  risks       Risk[]
  summary     Summary?
  analytics   Analytics?
}

model Transcript {
  id          String   @id @default(uuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speakerName String
  speakerId   String?
  text        String
  translation String?
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())
}

enum ActionItemStatus {
  PENDING
  COMPLETED
}

model ActionItem {
  id               String           @id @default(uuid())
  meetingId        String
  meeting          Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  text             String
  assigneeId       String?
  assignee         User?            @relation("AssigneeActionItems", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeName     String?         // In case the assignee is not registered yet
  status           ActionItemStatus @default(PENDING)
  dueDate          DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  
  // External task integration fields
  externalId       String?
  externalUrl      String?
  externalPlatform String?
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
}

enum RiskStatus {
  OPEN
  RESOLVED
}

model Risk {
  id        String       @id @default(uuid())
  meetingId String
  meeting   Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  text      String
  severity  RiskSeverity @default(MEDIUM)
  status    RiskStatus   @default(OPEN)
  createdAt DateTime     @default(now())
}

model Summary {
  id                String   @id @default(uuid())
  meetingId         String   @unique
  meeting           Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  overview          String
  keyTakeaways      String
  keyDecisions      String?
  nextSteps         String?
  productivityScore Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Analytics {
  id                   String   @id @default(uuid())
  meetingId            String   @unique
  meeting              Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  duration             Int      @default(0)
  totalWords           Int      @default(0)
  talkTimeDistribution String   @default("{}") // JSON string of speaker -> seconds
  sentimentScore       Float    @default(0.0)
  engagementScore      Int      @default(100)
  speakerSentiment     String   @default("{}") // JSON string of speaker -> sentiment
  createdAt            DateTime @default(now())
}

model Team {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  members   User[]    @relation("TeamMembers")
  channels  Channel[]
}

model Channel {
  id          String           @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  teamId      String
  team        Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  messages    ChannelMessage[]
  meetings    Meeting[]
}

model ChannelMessage {
  id         String   @id @default(uuid())
  text       String
  createdAt  DateTime @default(now())
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation("SenderChannelMessages", fields: [senderId], references: [id], onDelete: Cascade)
  senderName String
}

model DirectMessage {
  id         String   @id @default(uuid())
  text       String
  createdAt  DateTime @default(now())
  senderId   String
  sender     User     @relation("SenderDirectMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceiverDirectMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

